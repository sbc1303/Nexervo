<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="760.0" prefWidth="1080.0" styleClass="root"
            stylesheets="@Estilo.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nexervo.controlador.ReservaControlador">
   <children>
      <ImageView fitHeight="90.0" fitWidth="220.0" layoutX="430.0" layoutY="10.0"
                 pickOnBounds="true" preserveRatio="true">
         <image><Image url="@Logo%20NEXERVO%20sin%20fondo.png" /></image>
      </ImageView>

      <HBox layoutX="790.0" layoutY="22.0" spacing="10.0">
         <Button text="Reservas" onAction="#onVerReservas" styleClass="boton-nav" prefWidth="120" prefHeight="35" />
         <Button text="Clientes"  onAction="#onVerClientes"  styleClass="boton-nav" prefWidth="120" prefHeight="35" />
      </HBox>

      <VBox layoutX="30.0" layoutY="115.0" prefWidth="470.0" spacing="10.0">
         <children>
            <Label text="NUEVA RESERVA" style="-fx-font-size:18px; -fx-text-fill:#00C6FF;" />
            <HBox spacing="10.0">
               <VBox HBox.hgrow="ALWAYS"><Label text="Nombre *" /><TextField fx:id="txtNombre" promptText="Nombre..." /></VBox>
               <VBox HBox.hgrow="ALWAYS"><Label text="Apellidos *" /><TextField fx:id="txtApellidos" promptText="Apellidos..." /></VBox>
            </HBox>
            <HBox spacing="10.0">
               <VBox HBox.hgrow="ALWAYS"><Label text="Telefono *" /><TextField fx:id="txtTelefono" promptText="600000000" /></VBox>
               <VBox HBox.hgrow="ALWAYS"><Label text="Email" /><TextField fx:id="txtEmail" promptText="correo@ejemplo.com" /></VBox>
            </HBox>
            <HBox spacing="10.0">
               <VBox HBox.hgrow="ALWAYS"><Label text="Comensales *" /><Spinner fx:id="spinnerComensales" editable="true" maxWidth="Infinity" /></VBox>
               <VBox HBox.hgrow="ALWAYS"><Label text="Fecha Reserva *" /><DatePicker fx:id="fechaReserva" maxWidth="Infinity" /></VBox>
            </HBox>
            <Label text="Turno y Hora *" />
            <ComboBox fx:id="comboHora" maxWidth="Infinity" promptText="Selecciona fecha primero..." />
            <Label text="Mesa Seleccionada *" />
            <TextField fx:id="txtMesaSeleccionada" editable="false"
                       promptText="Selecciona una mesa del mapa"
                       style="-fx-text-fill: #00C6FF; -fx-font-weight: bold;" />
            <Label text="Alergenos e Intolerancias (seleccion multiple):" />
            <ListView fx:id="listaAlergias" prefHeight="110.0" />
            <Label fx:id="lblSeleccionadas" text="Ninguna seleccionada"
                   style="-fx-text-fill:#FFC107; -fx-font-size:11px;" />
            <Label text="Preferencias / Observaciones:" />
            <TextArea fx:id="txtObservaciones" prefHeight="60.0" wrapText="true"
                      promptText="Mesa especial, ocasion, preferencias..." />
            <HBox alignment="CENTER" spacing="15.0">
               <padding><Insets top="5"/></padding>
               <Button onAction="#onConfirmarClick" prefHeight="45.0" prefWidth="210.0"
                       styleClass="boton-confirmar" text="CONFIRMAR RESERVA" />
               <Button onAction="#onLimpiarClick" prefHeight="45.0" prefWidth="110.0"
                       styleClass="boton-secundario" text="LIMPIAR" />
            </HBox>
         </children>
      </VBox>

      <VBox alignment="TOP_CENTER" layoutX="545.0" layoutY="115.0"
            AnchorPane.rightAnchor="20.0" spacing="12.0">
         <children>
            <Label text="SALA" style="-fx-font-size:20px; -fx-text-fill:#00C6FF; -fx-font-weight:bold;" />
            <Label text="Selecciona fecha y turno para ver disponibilidad"
                   style="-fx-font-size:11px; -fx-text-fill:#888888;" />
            <HBox spacing="18.0" alignment="CENTER">
               <Label text="LIBRE"   style="-fx-text-fill:#00E676; -fx-font-weight:bold;" />
               <Label text="OCUPADA" style="-fx-text-fill:#FF3366; -fx-font-weight:bold;" />
               <Label text="ELEGIDA" style="-fx-text-fill:#FFC107; -fx-font-weight:bold;" />
            </HBox>
            <GridPane fx:id="gridMapa" hgap="12.0" vgap="12.0" visible="false" alignment="CENTER">
               <children>
                  <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M1" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M2" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M3" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                  <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M4" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M5" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M6" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                  <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M7" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                  <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M8" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                  <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M9" GridPane.columnIndex="2" GridPane.rowIndex="2" />
               </children>
                        <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M10" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M11" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Button prefHeight="70.0" prefWidth="100.0" styleClass="mesa-base" text="M12" GridPane.columnIndex="2" GridPane.rowIndex="3" />
         </GridPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
