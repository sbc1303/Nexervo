<configuration>

    <!-- Consola: para ver los logs mientras se desarrolla -->
    <appender name="CONSOLA" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{25} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Fichero rotativo: guarda 30 días de logs en la carpeta logs/ -->
    <appender name="FICHERO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/nexervo.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/nexervo.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger{35} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Paquetes propios en DEBUG para ver más detalle en desarrollo -->
    <logger name="datos"    level="DEBUG"/>
    <logger name="servicio" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="CONSOLA"/>
        <appender-ref ref="FICHERO"/>
    </root>

</configuration>
